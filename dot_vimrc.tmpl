" -------------------------------------------
" Core
" -------------------------------------------
set nocompatible               " Must be first — disables Vi compatibility
filetype plugin indent on      " Enable filetype detection, plugins, and indent rules
syntax on                      " Enable syntax highlighting


" -------------------------------------------
" Plugin Management
" -------------------------------------------
" Auto-install vim-plug if missing
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
endif

call plug#begin('~/.vim/bundle')
Plug 'catppuccin/vim', { 'as': 'catppuccin' }           " Color scheme
Plug 'jiangmiao/auto-pairs'                              " Auto-close brackets and quotes
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }     " FZF binary
Plug 'junegunn/fzf.vim'                                  " FZF commands (:Files, :Buffers, :GFiles)
Plug 'preservim/nerdtree'                                " File tree navigation
Plug 'tpope/vim-commentary'                              " Commenting (gcc / gc)
Plug 'tpope/vim-fugitive'                                " Git integration (:Git, :Gblame, :Gdiff)
Plug 'tpope/vim-sensible'                                " Sensible defaults
Plug 'tpope/vim-surround'                                " Surround text with quotes/brackets
call plug#end()


" -------------------------------------------
" Color Scheme
" -------------------------------------------
let g:catppuccin_flavour = "macchiato"
let g:catppuccin_terminal_colors = v:true
let g:catppuccin_transparent_background = v:true
colorscheme catppuccin_macchiato


" -------------------------------------------
" Search
" -------------------------------------------
set gdefault               " Apply global flag by default for substitutions
set hlsearch               " Highlight search results
set ignorecase             " Ignore case in search
set incsearch              " Show matches while typing
set showmatch              " Highlight matching brackets
set smartcase              " Case-sensitive when pattern contains uppercase


" -------------------------------------------
" Appearance
" -------------------------------------------
set background=dark        " Dark background
set colorcolumn=80         " Visual guide at column 80
set cursorcolumn           " Highlight current column
set cursorline             " Highlight current line
set display=lastline       " Show as much as possible of a long last line
set encoding=utf-8         " UTF-8 encoding
set laststatus=2           " Always show status line
set nowrap                 " Disable line wrapping (F12 toggles)
set number                 " Show line numbers
set norelativenumber       " Disable relative line numbers
set ruler                  " Show cursor position
set scrolloff=5            " Keep 5 lines visible above/below cursor
set showbreak=▹            " Marker shown at the start of wrapped lines
set showcmd                " Show partial commands in status line
set showmode               " Show current mode (INSERT / VISUAL / etc.)
set termguicolors          " True color support
set title                  " Show filename in window title bar
set visualbell             " Flash instead of beeping


" -------------------------------------------
" Indentation
" -------------------------------------------
set autoindent             " Carry indent to new lines
set expandtab              " Spaces instead of tabs
set shiftround             " Round indent to shiftwidth multiple
set shiftwidth=2           " 2-space indent
set smartindent            " Smart auto-indent on new lines
set softtabstop=2          " Backspace deletes 2 spaces at a time
set tabstop=2              " Tab displays as 2 spaces


" -------------------------------------------
" Editing Behaviour
" -------------------------------------------
set backspace=indent,eol,start  " Backspace over everything in insert mode
set formatoptions=qrn1j         " q=gq on comments, r=continue comment on newline,
                                " n=numbered lists, 1=no break after single-char word,
                                " j=remove comment leader when joining lines
set hidden                      " Allow switching unsaved buffers
set history=1000                " Keep 1000 lines of command history
set matchtime=3                 " Tenths of second to show matching bracket
set nofoldenable                " Start with all folds open
set nomodeline                  " Disable modelines (security risk — CVE vector)
set wildmenu                    " Enhanced command-line completion
set wildmode=list:longest       " Show completion list, complete to longest match


" -------------------------------------------
" Clipboard
" -------------------------------------------
{{- if eq .chezmoi.os "darwin" }}
set clipboard=unnamed           " macOS system clipboard (pbcopy/pbpaste)
{{- else }}
set clipboard=unnamedplus       " Linux/X11 system clipboard
{{- end }}


" -------------------------------------------
" Files, Swap, Backup, and Undo
" -------------------------------------------
" Create central directories on first run
for s:dir in [expand('~/.vim/swap'), expand('~/.vim/backup'), expand('~/.vim/undo')]
  if !isdirectory(s:dir)
    call mkdir(s:dir, 'p')
  endif
endfor

set swapfile
set directory=~/.vim/swap//    " // = embed full path in swap filename (avoids collisions)

set backup
set backupdir=~/.vim/backup//

set undofile                   " Persistent undo across sessions
set undodir=~/.vim/undo//

{{- if eq .chezmoi.os "darwin" }}
set backupskip=/tmp/*,/var/tmp/*,/private/tmp/*
{{- else }}
set backupskip=/tmp/*,/var/tmp/*
{{- end }}

set wildignore+=*.pyc,*.pyo,*.swp,*.bak
set wildignore+=*/.git/*,*/node_modules/*,*/__pycache__/*
set wildignore+=*.jpg,*.jpeg,*.png,*.gif,*.ico

set dictionary=/usr/share/dict/words
set shell=$SHELL


" -------------------------------------------
" Key Mappings
" -------------------------------------------
" Window navigation
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Session management (\ss = save, \sr = restore)
nnoremap <Leader>ss :mksession! ~/.vim-session.vim<CR>
nnoremap <Leader>sr :source ~/.vim-session.vim<CR>

" FZF (\b = buffers, \f = files, \g = git files)
nnoremap <Leader>b :Buffers<CR>
nnoremap <Leader>f :Files<CR>
nnoremap <Leader>g :GFiles<CR>

" Tab management
nnoremap <F5> :tabe<CR>
nnoremap <F6> gt
nnoremap <F7> gT
nnoremap <F8> <C-W>gF:tabm<CR>

" Toggle line wrap
nnoremap <F12> :set wrap!<CR>


" -------------------------------------------
" NERDTree
" -------------------------------------------
nnoremap <leader>n :NERDTreeFocus<CR>
nnoremap <C-n> :NERDTree<CR>
nnoremap <C-t> :NERDTreeToggle<CR>

let NERDTreeFileLines=1
let NERDTreeIgnore=['\.git$', '\~$']
let NERDTreeNaturalSort=1
let NERDTreeShowHidden=1
let NERDTreeShowLineNumbers=1
let NERDTreeSortHiddenFirst=1


" -------------------------------------------
" Auto Commands
" -------------------------------------------
augroup vimrc_autocmds
  autocmd!
  " Auto-install missing plugins on startup
  autocmd VimEnter * if len(filter(values(g:plugs), '!isdirectory(v:val.dir)'))
    \| PlugInstall --sync | source $MYVIMRC
    \| endif
  " Reload vimrc automatically on save
  autocmd BufWritePost $MYVIMRC source $MYVIMRC
augroup END
