# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

# Catppuccin Macchiato palette reference:
# Text:     #cad3f5  Blue:    #8aadf4  Green:   #a6da95
# Red:      #ed8796  Peach:   #f5a97f  Surface: #494d64

# Use the Catppuccin Mocha palette defined at the bottom
palette = "catppuccin_mocha"

scan_timeout = 10
add_newline = true

format = """\
$all\
$git_metrics\
$cmd_duration\
$fill\
$time\
$line_break\
$jobs\
$battery\
$status\
$os\
$container\
$shell\
$character\
"""

# ─────────────────────────────────────────
# Prompt character
# ─────────────────────────────────────────

[character]
success_symbol = '[➜](bold green)'
error_symbol = '[✗](bold red)'
vimcmd_symbol = '[](bold fg:color_bright_green)'
vimcmd_replace_one_symbol = '[](bold fg:color_purple)'
vimcmd_replace_symbol = '[](bold fg:color_purple)'
vimcmd_visual_symbol = '[](bold fg:color_yellow)'

# ─────────────────────────────────────────
# Shell / Identity
# ─────────────────────────────────────────
[fill]
symbol = " "

[time]
disabled = false
style = "bold #cad3f5"
format = "[$time]($style)"
=======
[fill]
symbol = " "

[time]
disabled = false
style = "bold #cad3f5"
time_format = "%R"
format = "[$time]($style)"

[username]
style_user = "bold #8aadf4"
style_root = "bold #ed8796"
format = "[$user]($style) "
disabled = false
show_always = true

[hostname]
ssh_only = false
format = 'on [$hostname](bold #f5a97f) '
trim_at = "."
disabled = false

[cmd_duration]
disabled = false
min_time = 2000
show_milliseconds = false
style = "bold italic #a6da95"
format = '[[  $duration  ]]'


[directory]
style = "fg:#cad3f5 bg:#8aadf4"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "…/"
read_only = " "
truncate_to_repo = true

[directory.substitutions]
"Documents" = "󰈙"
"Downloads" = ""
"Music" = ""
"Pictures" = ""

[shell]
fish_indicator = '󰈺'
powershell_indicator = ''
unknown_indicator = '❓'
style = 'bold #8aadf4'
disabled = false

# ─────────────────────────────────────────
# Git
# ─────────────────────────────────────────

[git_branch]
symbol = '🌿 '
truncation_length = 20
truncation_symbol = '…'
style = "bold #8aadf4"

[git_commit]
commit_hash_length = 7
tag_symbol = '🏷️ '

[git_state]
format = '[\($state( $progress_current of $progress_total)\)]($style) '
cherry_pick = '[🍒 PICKING](bold #ed8796)'

[git_metrics]
added_style = 'bold #a6da95'
deleted_style = 'bold #ed8796'
format = '[+$added]($added_style)/[-$deleted]($deleted_style) '
disabled = false

[git_status]
ahead = '⇡${count}'
behind = '⇣${count}'
conflicted = '🏳️'
deleted = '🗑️'
diverged = '⇕⇡${ahead_count}⇣${behind_count}'
modified = '📝'
renamed = '🔀'
staged = '[++\($count\)](#a6da95)'
stashed = '📦'
up_to_date = '✓'
untracked = '🤷'

[git_metrics]
added_style = 'bold #a6da95'
deleted_style = 'bold #ed8796'
format = '[+$added]($added_style)/[-$deleted]($deleted_style) '
disabled = true

[golang]
symbol = ""
style = "bg:#494d64"
format = '[[ $symbol ($version) ](fg:#8aadf4 bg:#494d64)]($style)'

[kubernetes]
disabled = false

[[kubernetes.contexts]]
context_pattern = "production"
user_pattern = "admin_user"
style = "bold #ed8796"
context_alias = "prod"
user_alias = "admin"

[[kubernetes.contexts]]
context_pattern = ".*fortress.*"
style = "bold #a6da95"
symbol = "💔"
context_alias = "talos"

# ─────────────────────────────────────────
# Cloud / Infrastructure
# ─────────────────────────────────────────

[aws]
symbol = " "

[docker_context]
symbol = ""
format = "via [$symbol$context]($style) "
style = "bold #8aadf4"
only_with_files = true
detect_files = ["docker-compose.yml", "docker-compose.yaml", "Dockerfile"]

[terraform]
format = '[🏎️💨 $version$workspace]($style) '
style = 'bold #f5a97f'

[vagrant]
format = 'via [⍱ $version](bold #cad3f5) '

# ─────────────────────────────────────────
# Languages
# ─────────────────────────────────────────

[golang]
symbol = ""
style = "bg:#494d64"
format = '[[ $symbol ($version) ](fg:#8aadf4 bg:#494d64)]($style)'

[nodejs]
symbol = ""
style = "bg:#494d64"
format = '[[ $symbol ($version) ](fg:#8aadf4 bg:#494d64)]($style)'

[php]
symbol = ""
style = "bg:#494d64"
format = '[[ $symbol ($version) ](fg:#8aadf4 bg:#494d64)]($style)'

[python]
symbol = '🐍'
format = 'via [$symbol python ($version)(\($virtualenv\)) ]($style)'
style = "bold #f5a97f"
pyenv_prefix = "venv "
python_binary = ["./venv/bin/python", "python", "python3", "python2"]
detect_extensions = ["py"]
version_format = "v${raw}"

[rust]
symbol = ""
style = "bg:#494d64"
format = '[[ $symbol ($version) ](fg:#8aadf4 bg:#494d64)]($style)'

# ─────────────────────────────────────────
# System
# ─────────────────────────────────────────

[jobs]
symbol = '✦ '
number_threshold = 1
symbol_threshold = 1

[memory_usage]
symbol = " "
style = "bold #f5a97f"

[shell]
fish_indicator = '󰈺'
powershell_indicator = ''
zsh_indicator = '󱆃'
unknown_indicator = '❓'
style = 'bold #8aadf4'
disabled = false

[status]
style = 'bg:#8aadf4'
symbol = '🔴'
format = '[\[$symbol$common_meaning$signal_name$maybe_int\]]($style) '
map_symbol = true
disabled = false

[sudo]
style = 'bold #a6da95'
symbol = '👑 '
disabled = false

# ─────────────────────────────────────────
# Timing / UI
# ─────────────────────────────────────────

[cmd_duration]
min_time = 2000
show_milliseconds = false
style = "bold italic #a6da95"
disabled = false

[fill]
symbol = " "

[time]
disabled = false
style = "bold #cad3f5"
format = "[$time]($style)"
