# Startup profiling — uncomment the two lines below to measure shell startup time.
# zmodload zsh/zprof

# history
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000

# options
setopt EXTENDED_HISTORY
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_SPACE
setopt INC_APPEND_HISTORY_TIME
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_MINUS
setopt AUTO_MENU
setopt ALWAYS_TO_END
cdpath=("$HOME/SourceCode")

# for home brew
export HOMEBREW_NO_AUTO_UPDATE=1

# vi mode
bindkey -v

# Keep Vi mode, but disable mouse tracking
zmodload zsh/terminfo
printf '%s' "${terminfo[rmkx]}"

# completion
zstyle :compinstall filename "$HOME/.zshrc"
autoload -Uz compinit
compinit

# git & ssh-agent --> using GPG further down.

# load starship
eval "$(starship init zsh)"

# --- shell / environment ---
alias dt='date "+%F %T"'
alias h='history'
alias j='jobs -l'
alias libpath='echo -e ${LD_LIBRARY_PATH//:/\\n}'
alias path='echo -e ${PATH//:/\\n}'
alias which='type -a'

# --- filesystem ---
alias backup='mkdir -p .backups/$(date +%Y%m%dT%H%M) 2>/dev/null; cp -R * .backups/$(date +%Y%m%dT%H%M)/'
alias dsize='du -sk * | sort -n --'
alias du='dust'
alias grep='grep --color=auto'
alias less='less --quiet --tabs=4'
alias ll='lsd -l'
alias lt='ls -latr'
alias t1='tree -L 1'
alias t2='tree -L 2'
alias t3='tree -L 3'
{{- if eq .chezmoi.os "darwin" }}
alias caff='caffeinate -disu -t 604800'
alias numfmt='gnumfmt'
{{- end }}

# --- network ---
alias netwatch='watch -n 15 -d "lsof -n -i | grep -e LISTEN -e ESTABLISHED"'
alias nmap-full='sudo nmap -p0-65535 -T5'
alias ping='prettyping --nolegend'

# --- git ---
alias ga='git add'
alias gc='git commit'
alias gco='git checkout'
alias gld='git log --oneline --graph --decorate --abbrev-commit --all'
alias gl1='git log --oneline'
alias gl1h='git log --oneline | head'
alias glp="git -c core.pager='less -SRF' log --oneline --graph --decorate"
alias gp='git push'
alias gs='git status'

gt() {
    git tag -l "*${1}*" | sort --version-sort
}

gtp() {
    git tag -l "${1}*${2:-prod}*" | sort --version-sort
}

# --- kubernetes ---
alias k='kubectl'
alias k9s='k9s --refresh 6 --crumbsless --all-namespaces'
alias kdash-token='printf "\n\n"; kubectl -n kubernetes-dashboard create token admin-user'
alias kpods='watch -n 6 "kubectl get pods --all-namespaces --field-selector metadata.namespace!=kube-system -o wide"'
alias ktop-cpu='watch -n 6 "kubectl top pods --use-protocol-buffers --sort-by=cpu --all-namespaces=true --field-selector metadata.namespace!=kube-system"'
alias ktop-mem='watch -n 6 "kubectl top pods --use-protocol-buffers --sort-by=memory --all-namespaces=true --field-selector metadata.namespace!=kube-system"'

# --- flux ---
alias fluxlogs='flux logs --all-namespaces --follow --tail=22'

frec() {
    flux reconcile source git flux-system -n flux-system && \
    flux reconcile kustomization flux-system --with-source -n flux-system
}

# --- code ---
alias code='codium'

# --- ansible ---
alias ap='ansible-playbook'
alias syn='ansible-playbook --syntax-check'

# --- chezmoi ---
czp() {
    chezmoi git -- add .
    chezmoi git -- commit -m "${*:-chore: update dotfiles}"
    chezmoi git -- push
}

# --- renovate ---
rdry() {
    LOG_LEVEL=debug renovate --dry-run=full
}

# --- utilities ---
genpasswd() {
    local l=${1:-26}
    export LC_ALL=C
    tr -dc A-Za-z0-9_ < /dev/urandom | head -c "${l}" | xargs
}

ww() {
    # The entire command must be passed as a single quoted string when it
    # contains pipes — e.g. ww 'flux get all -A | grep -v helmchart'
    # This is necessary because the shell consumes bare pipes before the
    # function receives its arguments.
    watch -n 6 "zsh -c ${(q)${(j: :)@}}"
}

# fuzzy search
if [ -f /usr/share/fzf/completion.zsh ]; then
  source /usr/share/fzf/completion.zsh
elif [ -f /opt/homebrew/opt/fzf/shell/completion.zsh ]; then
  source /opt/homebrew/opt/fzf/shell/completion.zsh
elif [ -f /usr/local/opt/fzf/shell/completion.zsh ]; then
  source /usr/local/opt/fzf/shell/completion.zsh
fi

if [ -f /usr/share/fzf/key-bindings.zsh ]; then
  source /usr/share/fzf/key-bindings.zsh
elif [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]; then
  source /usr/share/doc/fzf/examples/key-bindings.zsh
elif [ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]; then
  source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
elif [ -f /usr/local/opt/fzf/shell/key-bindings.zsh ]; then
  source /usr/local/opt/fzf/shell/key-bindings.zsh
fi

# fish like
if [ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
elif [ -f /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
  source /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh
elif [ -f /usr/local/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
  source /usr/local/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

if [ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
elif [ -f /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
elif [ -f /usr/local/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source /usr/local/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# gnupg
GPG_TTY=$(tty)
export GPG_TTY

# For SOPS
export SOPS_GPG_EXEC="gpg"
export SOPS_PGP_FP="{{ .signingkey }}"
export SOPS_GPG_KEYSERVER="hkps://keyserver.ubuntu.com"
export SOPS_AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"

# machine-local secrets (not tracked by chezmoi — contains tokens/PATs)
[[ -f "${HOME}/.zshrc.secrets" ]] && source "${HOME}/.zshrc.secrets"

# k8s — cache completions to avoid spawning subprocesses on every shell start
_cache_completion() {
  local cmd="$1" file="${HOME}/.zsh_cache/${1}_completion.zsh"
  mkdir -p "${HOME}/.zsh_cache"
  if [[ ! -f "$file" || "$(whence -p "$cmd")" -nt "$file" ]]; then
    "$cmd" completion zsh > "$file" 2>/dev/null
  fi
  source "$file"
}
[[ -x $(whence kubectl) ]] && _cache_completion kubectl
[[ -x $(whence helm) ]]    && _cache_completion helm
[[ -x $(whence flux) ]]    && _cache_completion flux && compdef _flux flux
#[[ -x $(whence saml2aws) ]] && eval "$( saml2aws --completion-script-zsh )"

