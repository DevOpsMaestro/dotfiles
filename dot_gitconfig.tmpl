# ─────────────────────────────────────────
# Identity
# ─────────────────────────────────────────
[user]
    name = DevOpsMaestro
    email = {{ .email }}
{{- if index . "signingkey" }}
    signingkey = {{ .signingkey }}
{{- end }}

[init]
    defaultBranch = main

# ─────────────────────────────────────────
# Core
# ─────────────────────────────────────────
[core]
    editor = nvim
    pager = delta
    autocrlf = false
    fsmonitor = true
    untrackedCache = true

# ─────────────────────────────────────────
# Credentials
# ─────────────────────────────────────────
{{- if eq .chezmoi.os "darwin" }}
[credential]
    helper = osxkeychain
{{- end }}

# ─────────────────────────────────────────
# Branching & Sorting
# ─────────────────────────────────────────
[branch]
    sort = -committerdate

[tag]
    sort = version:refname

# ─────────────────────────────────────────
# Diff & Merge
# ─────────────────────────────────────────
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true

[difftool "vimdiff"]
    path = vim

[merge]
    conflictstyle = zdiff3
    tool = vimdiff

[mergetool "vimdiff"]
    path = vim

[status]
    submoduleSummary = true

# ─────────────────────────────────────────
# Commit & Signing
# ─────────────────────────────────────────
[commit]
    verbose = true
    gpgsign = true

[gpg]
    format = openpgp

# ─────────────────────────────────────────
# Rebase & Rerere
# ─────────────────────────────────────────
[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[rerere]
    enabled = true
    autoupdate = true

# ─────────────────────────────────────────
# Remote Operations
# ─────────────────────────────────────────
[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[pull]
    rebase = true

[fetch]
    prune = true
    pruneTags = true
    all = true

# ─────────────────────────────────────────
# Display & Paging
# ─────────────────────────────────────────
[color]
    diff = true
    interactive = true
    status = true

[color "decorate"]
    HEAD = bold blink italic 196
    branch = 214
    tag = bold 222

[column]
    ui = auto

[log]
    graphColors = bold 160, blink 231 bold 239, bold 166, bold black 214, bold green, bold 24, cyan

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    features = decorations
    light = false
    line-numbers = true
    navigate = true
    syntax-theme = base16-256

[interactive]
    diffFilter = delta --color-only --features=interactive

# ─────────────────────────────────────────
# Help
# ─────────────────────────────────────────
[help]
    autocorrect = prompt

# ─────────────────────────────────────────
# URL Rewrites
# ─────────────────────────────────────────
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/

# ─────────────────────────────────────────
# Aliases
# ─────────────────────────────────────────
[alias]
    # --- full decorated graph (used as foundation for vtree) ---
    logx   = log --all --graph --decorate=short --color --format=format:'%C(bold blue)%h%C(reset)+%C(dim black)(%cr)%C(reset)+%C(auto)%d%C(reset)++\n+++       %C(bold black)%an%C(reset)%C(black): %s%C(reset)'
    vtree  = !bash -c '"                                                                                     \
        while IFS=+ read -r hash time branch message; do                                                \
            timelength=$(echo \"$time\" | sed -E \"s:[^ ][[]([0-9]{1,2}(;[0-9]{1,2})?)?m::g\");     \
            timelength=$(echo \"16+${#time}-${#timelength}\" | bc);                                 \
            printf \"%${timelength}s    %s %s %s\n\" \"$time\" \"$hash\" \"$branch\" \"$message\";  \
        done < <(git logx && echo);"'

    # --- oneline graph (suffix a = all refs, s = simplified by decoration) ---
    logg   = log --color --date-order --graph --oneline --decorate
    logga  = log --color --date-order --graph --oneline --decorate --all
    loggs  = log --color --date-order --graph --oneline --decorate --simplify-by-decoration
    loggsa = log --color --date-order --graph --oneline --decorate --simplify-by-decoration --all

    # --- graph with absolute date (suffix a = all refs) ---
    logd   = log --color --date-order --date=local --graph --format="%C(auto)%h%Creset %C(blue bold)%ad%Creset %C(auto)%d%Creset %s"
    logda  = log --color --date-order --date=local --graph --format="%C(auto)%h%Creset %C(blue bold)%ad%Creset %C(auto)%d%Creset %s" --all

    # --- graph with relative date (suffix a = all refs) ---
    logdr  = log --color --date-order --graph --format="%C(auto)%h%Creset %C(blue bold)%ar%Creset %C(auto)%d%Creset %s"
    logdra = log --color --date-order --graph --format="%C(auto)%h%Creset %C(blue bold)%ar%Creset %C(auto)%d%Creset %s" --all

    # --- basic graph (all refs) ---
    loga   = log --graph --color --decorate --all

    # --- truncated subject, useful for repos without body commits ---
    logt   = log --graph --color --format="%C(auto)%h %d %<|(100,trunc) %s"
    logta  = log --graph --color --format="%C(auto)%h %d %<|(100,trunc) %s" --all
    logtsa = log --graph --color --format="%C(auto)%h %d %<|(100,trunc) %s" --all --simplify-by-decoration

    # --- tabular: columnar layout with hash, relative time, ref, subject ---
    tably  = log --all --graph --decorate=short --color --pretty=format:'+%C(bold 214)%<(7,trunc)%h%C(reset)+%C(dim white)%>(12,trunc)%cr%C(reset)+%C(auto)%>(15,trunc)%D%C(reset)+%C(white)%s%C(reset)'
